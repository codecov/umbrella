# syntax=docker/dockerfile:1.4
ARG REQUIREMENTS_IMAGE

FROM $REQUIREMENTS_IMAGE as test_reqs

ENV UV_LINK_MODE=copy \
    UV_COMPILE_BYTECODE=1 \
    UV_PYTHON_DOWNLOADS=never \
    UV_PROJECT_ENVIRONMENT=/app

RUN apt-get update
RUN apt-get install -y git build-essential netcat-traditional
RUN git config --global --add safe.directory /app || true

# `uv pip install --group` has no --frozen equivalent and silently re-resolves
# dev-only deps against live PyPI on every rebuild, ignoring uv.lock. That let
# vcrpy drift past a cassette-matching regression (>=8.2.0) and break Worker
# CI: https://github.com/kevin1024/vcrpy/issues/1013 (COV-45). Export the dev
# group through --frozen instead, so it's pinned exactly like the main deps.
RUN --mount=type=cache,target=/root/.cache/uv \
    --mount=type=bind,source=./pyproject.toml,target=./pyproject.toml \
    --mount=type=bind,source=./uv.lock,target=./uv.lock \
    --mount=type=bind,source=libs/shared,target=libs/shared \
    uv export --only-group dev --no-hashes --frozen --format requirements-txt > dev-requirements.txt && \
    uv pip install --no-deps -r dev-requirements.txt --system
